{
    "name": "alisafari-dev/laravel-keycloak-sso",
    "description": "Keycloak SSO integration for Laravel with prefixed routes and Socialite.",
    "version": "1.0.1",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "A.safari",
            "email": "ali.safari.anzabi@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/socialite": "^5.27",
        "socialiteproviders/keycloak": "^5.3"
    },
    "autoload": {
        "psr-4": {
            "Asafari\\LaravelKeycloakSso\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Asafari\\LaravelKeycloakSso\\KeycloakSsoServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
